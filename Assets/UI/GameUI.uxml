        <ui:Label text="Game Over" name="GameOverMessage" focusable="false" style="color: rgb(255, 255, 255); -unity-text-align: upper-center; -unity-font-style: bold; font-size: 64px; justify-content: space-around; align-items: center; -unity-font-definition: url(&quot;project://database/Assets/3rd%20Party%20Assets/Roguelike2D/TutorialAssets/Fonts/PressStart2P-Regular.ttf?fileID=12800000&amp;guid=b284a6525342f44599e9ce79e37c2d61&amp;type=3#PressStart2P-Regular&quot;);"/>
    </ui:VisualElement>
    <ui:VisualElement name="MainMenuPanel" style="flex-grow: 1; position: absolute; bottom: 0; left: -2px; top: 0; right: 2px; width: 100%; height: 100%; background-color: rgb(0, 8, 31); display: flex;">
        <ui:Label text="Eat or Die" name="GameTitle" style="justify-content: center; align-items: center; align-self: center; align-content: center; -unity-font-definition: url(&quot;project://database/Assets/3rd%20Party%20Assets/Roguelike2D/TutorialAssets/Fonts/PressStart2P-Regular.ttf?fileID=12800000&amp;guid=b284a6525342f44599e9ce79e37c2d61&amp;type=3#PressStart2P-Regular&quot;); color: rgb(255, 255, 255); font-size: 80%; position: absolute; top: 332px; left: 134px; white-space: normal; width: 881px;"/>
        <ui:Button text="Start" name="PlayButton" style="position: absolute; top: 622px; justify-content: center; align-self: center; align-content: center; width: 50%; font-size: 30%; border-top-left-radius: 20px; border-top-right-radius: 20px; border-bottom-right-radius: 20px; border-bottom-left-radius: 20px; left: 259px; background-color: rgb(37, 255, 0);"/>
        <ui:Button text="Exit" name="QuitButton" style="position: absolute; top: 744px; justify-content: center; align-self: center; align-content: center; width: 50%; font-size: 30%; border-top-left-radius: 20px; border-top-right-radius: 20px; border-bottom-right-radius: 20px; border-bottom-left-radius: 20px; left: 260px; background-color: rgb(255, 23, 0);"/>
    </ui:VisualElement>
