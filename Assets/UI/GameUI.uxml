        <ui:Label text="Paused" name="PauseLabel" style="justify-content: center; align-items: center; align-self: center; align-content: center; position: absolute; top: 20%; font-size: 70%; -unity-font-definition: url(&quot;project://database/Assets/3rd%20Party%20Assets/Roguelike2D/TutorialAssets/Fonts/PressStart2P-Regular.ttf?fileID=12800000&amp;guid=b284a6525342f44599e9ce79e37c2d61&amp;type=3#PressStart2P-Regular&quot;); -unity-text-align: upper-center; color: rgb(255, 255, 255);"/>
        <ui:Button text="Resume" name="ResumeButton" style="top: 40%; position: absolute; justify-content: center; align-items: center; align-self: center; align-content: center; font-size: 30%; border-top-left-radius: 20px; border-top-right-radius: 20px; border-bottom-right-radius: 20px; border-bottom-left-radius: 20px;"/>
        <ui:Button text="Restart" name="RestartButton" style="top: 60%; position: absolute; justify-content: center; align-items: center; align-self: center; align-content: center; font-size: 30%; border-top-left-radius: 20px; border-top-right-radius: 20px; border-bottom-right-radius: 20px; border-bottom-left-radius: 20px;"/>
        <ui:Button text="Main Menu" name="MenuQuitButton" style="top: 80%; position: absolute; justify-content: center; align-items: center; align-self: center; align-content: center; font-size: 30%; border-top-left-radius: 20px; border-top-right-radius: 20px; border-bottom-right-radius: 20px; border-bottom-left-radius: 20px;"/>
